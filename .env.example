# -----------------------------------------------------------------
# All variables below are OPTIONAL.
# The skills work in draft-only mode with nothing set.
# Add a PUBLORA_API_KEY to enable auto-posting tweets and threads.
# -----------------------------------------------------------------

# Publora API key - sign up free at https://app.publora.com/signup
PUBLORA_API_KEY=sk_your_key_here

# X (Twitter) platform connection ID (format: twitter-123456789)
# Find this in the Publora dashboard: Channels then your X account.
# Copy the whole thing including the twitter- prefix.
X_PLATFORM_ID=twitter-your_id_here

# -----------------------------------------------------------------
# Apify token (optional) - if you later wire a tweet-reading actor,
# the read-side skills can fetch tweet text instead of asking you to
# paste it. Without a token, hook-extractor and reply-drafter fall
# back to asking you to paste the tweet.
#
# Sign up: https://console.apify.com/sign-up
# Token:   https://console.apify.com/settings/integrations
# -----------------------------------------------------------------
APIFY_TOKEN=apify_api_your_token_here

# -----------------------------------------------------------------
# Advanced (Tier 2): if you've built your own poster with Claude Code or Codex
# (e.g. on the X API v2), set this to the command the skills invoke on approval.
# Leave unset unless you actually have a custom poster working.
# -----------------------------------------------------------------
# X_SKILLS_CUSTOM_POSTER=python /path/to/my-poster.py
